    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.6",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
